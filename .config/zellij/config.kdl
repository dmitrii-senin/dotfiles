// Zellij Configuration — press Alt+/ inside zellij for the full keymap
//
// Tmux prefix (Ctrl+Space) — discoverable mode router
//   ?  help          p  pane mode      t  tab mode
//   r  resize mode   /  scroll mode    o  session mode
//   s  split down    v  split right    f  new floating pane
//   n  new tab       x  close pane     q  quit
//
// Quick keys (any non-locked mode)
//   Alt+s/v/f   new pane down / right / floating
//   Alt+x       close pane
//   Alt+r       rename current tab
//   Alt+n       new tab
//   Alt+1..9    jump to tab N
//   Alt+j/k     prev / next tab
//   Alt+H/L     move tab left / right
//   Alt+w       toggle floating panes (show/hide)
//   Alt+z       zoom (toggle fullscreen) current pane
//   Alt+p       pin / unpin focused floating pane
//   Alt+e       embed ↔ float toggle for focused pane
//   Alt+u       enter scroll mode + page up
//   Alt+d       detach session
//   Alt+q       quit zellij (session stays resurrectable)
//   Alt+Q       kill+delete current session (with confirm)
//   Alt+o       open session manager (rename/switch sessions)
//   Alt+/       open this keymap (help.txt)
//
// Vim-aware navigation
//   Ctrl+h/j/k/l  seamless vim ↔ zellij pane focus
//
// Locking
//   Alt+g       toggle locked mode (passes everything to terminal)

default_layout "default"
theme "catppuccin-macchiato"
pane_frames false
copy_on_select true
show_startup_tips false

keybinds clear-defaults=true {
    locked {
        bind "Alt g" { SwitchToMode "Normal"; }
    }

    normal {
        bind "Alt g" { SwitchToMode "Locked"; }
        bind "Ctrl Space" { SwitchToMode "Tmux"; }
    }

    tmux {
        bind "Esc" { SwitchToMode "Normal"; }
        bind "?" {
            Run "bash" "-c" "less ~/.config/zellij/help.txt" {
                close_on_exit true
                floating true
            };
            SwitchToMode "Normal";
        }
        bind "p" { SwitchToMode "Pane"; }
        bind "t" { SwitchToMode "Tab"; }
        bind "r" { SwitchToMode "Resize"; }
        bind "/" { SwitchToMode "Scroll"; }
        bind "o" { SwitchToMode "Session"; }
        bind "h" { MoveFocus "Left"; SwitchToMode "Normal"; }
        bind "j" { MoveFocus "Down"; SwitchToMode "Normal"; }
        bind "k" { MoveFocus "Up"; SwitchToMode "Normal"; }
        bind "l" { MoveFocus "Right"; SwitchToMode "Normal"; }
        bind "s" { NewPane "Down"; SwitchToMode "Normal"; }
        bind "v" { NewPane "Right"; SwitchToMode "Normal"; }
        bind "f" {
            Run "zsh" { floating true; close_on_exit true; };
            SwitchToMode "Normal";
        }
        bind ">" { MovePane; SwitchToMode "Normal"; }
        bind "n" { NewTab; SwitchToMode "Normal"; }
        bind "x" { CloseFocus; SwitchToMode "Normal"; }
        bind "q" { Quit; }
    }

    pane {
        bind "Esc" "Enter" "q" { SwitchToMode "Normal"; }
        bind "s" { NewPane "Down"; SwitchToMode "Normal"; }
        bind "v" { NewPane "Right"; SwitchToMode "Normal"; }
        bind "x" { CloseFocus; SwitchToMode "Normal"; }
        bind "f" { ToggleFocusFullscreen; SwitchToMode "Normal"; }
        bind "w" { ToggleFloatingPanes; SwitchToMode "Normal"; }
        bind "p" { TogglePanePinned; SwitchToMode "Normal"; }
        bind "e" { TogglePaneEmbedOrFloating; SwitchToMode "Normal"; }
        bind "r" { SwitchToMode "RenamePane"; PaneNameInput 0; }
        bind "h" { MoveFocus "Left"; }
        bind "j" { MoveFocus "Down"; }
        bind "k" { MoveFocus "Up"; }
        bind "l" { MoveFocus "Right"; }
    }

    tab {
        bind "Esc" "Enter" "q" { SwitchToMode "Normal"; }
        bind "n" { NewTab; SwitchToMode "Normal"; }
        bind "x" { CloseTab; SwitchToMode "Normal"; }
        bind "r" { SwitchToMode "RenameTab"; TabNameInput 0; }
        bind "h" "j" { GoToPreviousTab; }
        bind "l" "k" { GoToNextTab; }
        bind "H" "J" { MoveTab "Left"; }
        bind "L" "K" { MoveTab "Right"; }
        bind "1" { GoToTab 1; SwitchToMode "Normal"; }
        bind "2" { GoToTab 2; SwitchToMode "Normal"; }
        bind "3" { GoToTab 3; SwitchToMode "Normal"; }
        bind "4" { GoToTab 4; SwitchToMode "Normal"; }
        bind "5" { GoToTab 5; SwitchToMode "Normal"; }
    }

    resize {
        bind "Esc" "Enter" "q" { SwitchToMode "Normal"; }
        bind "h" "Left" { Resize "Increase Left"; }
        bind "j" "Down" { Resize "Increase Down"; }
        bind "k" "Up" { Resize "Increase Up"; }
        bind "l" "Right" { Resize "Increase Right"; }
        bind "H" { Resize "Decrease Left"; }
        bind "J" { Resize "Decrease Down"; }
        bind "K" { Resize "Decrease Up"; }
        bind "L" { Resize "Decrease Right"; }
    }

    scroll {
        bind "Esc" "q" { SwitchToMode "Normal"; }
        bind "j" "Down" { ScrollDown; }
        bind "k" "Up" { ScrollUp; }
        bind "d" "Ctrl d" { HalfPageScrollDown; }
        bind "u" "Ctrl u" { HalfPageScrollUp; }
        bind "/" { SwitchToMode "EnterSearch"; SearchInput 0; }
        bind "e" { EditScrollback; SwitchToMode "Normal"; }
    }

    entersearch {
        bind "Esc" { SwitchToMode "Scroll"; }
        bind "Enter" { SwitchToMode "Search"; }
    }

    search {
        bind "Esc" "q" { SwitchToMode "Normal"; }
        bind "j" "Down" { ScrollDown; }
        bind "k" "Up" { ScrollUp; }
        bind "n" { Search "down"; }
        bind "N" { Search "up"; }
    }

    renametab {
        bind "Esc" { UndoRenameTab; SwitchToMode "Normal"; }
        bind "Enter" { SwitchToMode "Normal"; }
    }

    renamepane {
        bind "Esc" { UndoRenamePane; SwitchToMode "Normal"; }
        bind "Enter" { SwitchToMode "Normal"; }
    }

    session {
        bind "Esc" "Enter" "q" { SwitchToMode "Normal"; }
        bind "d" { Detach; }
        bind "q" { Quit; }
        bind "o" "Alt o" {
            LaunchPlugin "session-manager" {
                floating true
            };
            SwitchToMode "Normal";
        }
    }

    // Quick keys (work in any non-locked mode)
    shared_except "locked" {
        bind "Alt j" { GoToPreviousTab; }
        bind "Alt k" { GoToNextTab; }
        bind "Alt w" { ToggleFloatingPanes; }
        bind "Alt z" { ToggleFocusFullscreen; }
        bind "Alt H" { MoveTab "Left"; }
        bind "Alt L" { MoveTab "Right"; }
        bind "Alt p" { TogglePanePinned; }
        bind "Alt e" { TogglePaneEmbedOrFloating; }
        bind "Alt n" { NewTab; }
        bind "Alt s" { NewPane "Down"; }
        bind "Alt v" { NewPane "Right"; }
        bind "Alt f" { Run "zsh" { floating true; close_on_exit true; }; }
        bind "Alt x" { CloseFocus; }
        bind "Alt r" { SwitchToMode "RenameTab"; TabNameInput 0; }
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }
        bind "Alt u" { SwitchToMode "Scroll"; HalfPageScrollUp; }
        bind "Alt d" { Detach; }
        bind "Alt q" { Quit; }
        bind "Alt Q" {
            Run "bash" "-c" "read -p 'Kill+delete current session \"$ZELLIJ_SESSION_NAME\"? [y/N] ' a && [[ \"$a\" =~ ^[Yy]$ ]] && zellij delete-session --force \"$ZELLIJ_SESSION_NAME\"" {
                floating true
                close_on_exit true
            };
        }
        bind "Alt o" {
            LaunchPlugin "session-manager" {
                floating true
            };
        }
        bind "Alt /" {
            Run "bash" "-c" "less ~/.config/zellij/help.txt" {
                close_on_exit true
                floating true
            };
        }
    }

    // Seamless vim/zellij pane navigation with Ctrl+h/j/k/l
    shared_except "locked" {
        bind "Ctrl h" {
            MessagePlugin "file:~/.config/zellij/plugins/vim-zellij-navigator.wasm" {
                name "move_focus_or_tab";
                payload "left";
                move_mod "ctrl";
            };
        }
        bind "Ctrl j" {
            MessagePlugin "file:~/.config/zellij/plugins/vim-zellij-navigator.wasm" {
                name "move_focus";
                payload "down";
                move_mod "ctrl";
            };
        }
        bind "Ctrl k" {
            MessagePlugin "file:~/.config/zellij/plugins/vim-zellij-navigator.wasm" {
                name "move_focus";
                payload "up";
                move_mod "ctrl";
            };
        }
        bind "Ctrl l" {
            MessagePlugin "file:~/.config/zellij/plugins/vim-zellij-navigator.wasm" {
                name "move_focus_or_tab";
                payload "right";
                move_mod "ctrl";
            };
        }
    }
}
